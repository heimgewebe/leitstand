# Copy to .env (do not commit .env)

# Server
PORT=3000

# Container deployments may bind inside an isolated network. Host exposure remains
# controlled by the compose override and must be deliberate.
LEITSTAND_BIND_HOST=127.0.0.1
# LEITSTAND_ALLOW_WIDE_BIND=false

# Strict runtime behavior.
# LEITSTAND_STRICT=1

# Read-only artifact projections.
# LEITSTAND_BUREAU_SNAPSHOT_PATH=/data/bureau-tasks.json
# LEITSTAND_CHECKOUT_SNAPSHOT_PATH=/data/checkout-inventory.json
# LEITSTAND_STORAGE_HEALTH_PATH=/data/storage-health.json
# LEITSTAND_ECOSYSTEM_MAP_MANIFEST_PATH=/data/ecosystem-map-artifact-manifest.json
# LEITSTAND_REPOGROUND_BUNDLES_PATH=/data/repoground-bundles.json
