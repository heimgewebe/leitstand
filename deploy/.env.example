# Copy to .env (do not commit .env)
# -----------------------------------------------------------------------------

# Server Configuration
PORT=3000
# Safe default for direct Node/systemd operation: loopback only.
# Docker Compose overrides the in-container host explicitly; host exposure is controlled by its ports override.
LEITSTAND_BIND_HOST=127.0.0.1
# Wildcard hosts 0.0.0.0 and :: are rejected unless this is explicitly true.
# LEITSTAND_ALLOW_WIDE_BIND=false

# Strict Mode (enable in production)
# LEITSTAND_STRICT=1

# Authentication (Events API)
# LEITSTAND_EVENTS_TOKEN=REQUIRED_IN_PROD_SET_VIA_ENV_ONLY
# NOTE: Do not put real secrets into .env.example

# Agent Control Surface (ACS) Integration
# LEITSTAND_ACS_URL=https://acs.internal
# LEITSTAND_ACS_VIEWER_TOKEN=OPTIONAL_SET_VIA_ENV_ONLY
# LEITSTAND_OPS_ALLOW_JOB_FALLBACK=false

# Ops Viewer Configuration
# LEITSTAND_REPOS=metarepo,wgx,leitstand

# Observatory Schema Ref Allowlist
# OBSERVATORY_SCHEMA_REF_ALLOWED_HOSTS=schemas.heimgewebe.org
