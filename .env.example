# Copy to .env (do not commit .env)

# Server
PORT=3000

# Safe default for direct Node/systemd operation: loopback only.
LEITSTAND_BIND_HOST=127.0.0.1

# Wildcard hosts 0.0.0.0 and :: are rejected unless explicitly acknowledged.
# LEITSTAND_ALLOW_WIDE_BIND=false

# Strict runtime behavior.
# LEITSTAND_STRICT=1

# Read-only artifact paths may be overridden by the dedicated producer contracts:
# LEITSTAND_BUREAU_SNAPSHOT_PATH=/path/to/bureau-tasks.json
# LEITSTAND_CHECKOUT_SNAPSHOT_PATH=/path/to/checkout-inventory.json
# LEITSTAND_STORAGE_HEALTH_PATH=/path/to/storage-health.json
# LEITSTAND_ECOSYSTEM_MAP_MANIFEST_PATH=/path/to/ecosystem-map-artifact-manifest.json
# LEITSTAND_REPOGROUND_BUNDLES_PATH=/path/to/repoground-bundles.json
