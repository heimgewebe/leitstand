<!DOCTYPE html>
<!-- Ops Viewer Template - Read-only view. No side effects allowed. -->
<html lang="de">
<head>
  <% if (locals.allowJobFallback) { %>
    <title>Ops Viewer (may trigger audit jobs)</title>
  <% } else { %>
    <title>Ops Viewer (read-only)</title>
  <% } %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Ops Viewer – Git-Health-Audit und Reparatur-Routinen aus dem Leitstand.">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-primary: #0a0e1a;
      --bg-secondary: #111827;
      --bg-card: rgba(17, 24, 39, 0.85);
      --bg-glass: rgba(255, 255, 255, 0.04);
      --border-glass: rgba(255, 255, 255, 0.08);
      --border-active: rgba(255, 255, 255, 0.15);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --accent: #3b82f6;
      --ok: #22c55e;
      --warn: #f59e0b;
      --fail: #ef4444;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
    }

    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 10px 20px;
      background: rgba(10, 14, 26, 0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-glass);
    }

    nav a {
      text-decoration: none;
      color: var(--text-secondary);
      font-size: 0.82em;
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 6px;
      transition: all 0.2s ease;
    }

    nav a:hover { color: var(--text-primary); background: var(--bg-glass); }
    nav a:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    nav a.active { color: var(--accent); background: rgba(59, 130, 246, 0.1); }
    nav .title { font-weight: 700; font-size: 0.9em; color: var(--text-primary); margin-right: 16px; }

    .main {
      max-width: 1080px;
      margin: 0 auto;
      padding: 48px 24px 96px;
    }

    .page-header {
      margin-bottom: 36px;
    }

    .page-header h1 {
      font-size: 1.9em;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 10px;
    }

    .page-header .subtitle {
      color: var(--text-secondary);
      font-size: 0.95em;
      max-width: 720px;
      line-height: 1.55;
    }

    .section {
      background: var(--bg-card);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border-glass);
      border-radius: 14px;
      padding: 22px 24px;
      margin-bottom: 20px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 20px;
    }

    select {
      background: var(--bg-secondary);
      color: var(--text-primary);
      border: 1px solid var(--border-glass);
      padding: 8px 12px;
      border-radius: 6px;
      font-size: 0.9em;
      cursor: pointer;
    }

    button {
      padding: 8px 16px;
      cursor: pointer;
      background: var(--accent);
      color: var(--text-primary);
      border: none;
      border-radius: 6px;
      font-weight: 500;
      font-size: 0.9em;
      transition: all 0.2s ease;
    }

    button:hover { background: rgba(59, 130, 246, 1.2); opacity: 0.9; }
    button:disabled { opacity: 0.5; cursor: not-allowed; }

    pre {
      background: var(--bg-secondary);
      color: var(--text-secondary);
      padding: 12px 14px;
      border-radius: 8px;
      overflow: auto;
      font-size: 0.75em;
      border: 1px solid var(--border-glass);
      max-height: 400px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    }

    .status-ok { color: var(--ok); font-weight: 600; }
    .status-warn { color: var(--warn); font-weight: 600; }
    .status-error { color: var(--fail); font-weight: 600; }

    .routine-card {
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      padding: 16px 18px;
      margin-bottom: 12px;
      border-radius: 10px;
      transition: all 0.2s ease;
    }

    .routine-card:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: var(--border-active);
    }

    .routine-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
      margin-bottom: 10px;
      color: var(--text-primary);
    }

    .routine-actions {
      margin-top: 12px;
      padding: 10px 12px;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 6px;
    }

    .acs-link {
      color: var(--accent);
      font-weight: 600;
      text-decoration: none;
      display: inline-block;
      margin-top: 6px;
    }

    .acs-link:hover { text-decoration: underline; }

    .acs-info {
      font-size: 0.85em;
      color: var(--text-secondary);
      margin-bottom: 16px;
      padding: 12px;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 8px;
    }

    .poll-indicator {
      margin-left: 10px;
      color: var(--text-muted);
      font-style: italic;
      display: none;
    }

    .not-configured {
      padding: 32px 24px;
      text-align: center;
      background: var(--bg-glass);
      border: 1px dashed var(--border-active);
      color: var(--text-secondary);
      border-radius: 12px;
    }

    .not-configured h2 {
      font-size: 1.3em;
      color: var(--text-primary);
      margin-bottom: 12px;
    }

    .not-configured p {
      font-size: 0.9em;
      line-height: 1.5;
      margin-bottom: 8px;
    }

    .not-configured code {
      background: var(--bg-secondary);
      padding: 2px 6px;
      border-radius: 4px;
      font-family: ui-monospace;
      color: var(--accent);
    }

    .error-box {
      background-color: rgba(239, 68, 68, 0.08);
      color: var(--text-secondary);
      border: 1px solid var(--border-glass);
      border-left: 4px solid var(--fail);
      padding: 14px 16px;
      margin-bottom: 16px;
      border-radius: 8px;
      white-space: pre-wrap;
      font-size: 0.85em;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    }

    .section-title {
      font-size: 0.72em;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <nav>
    <span class="title">Leitstand</span>
    <a href="/">Home</a>
    <a href="/observatory">Observatorium</a>
    <a href="/anatomy">Anatomie</a>
    <a href="/timeline">Zeitachse</a>
    <a href="/insights">Erkenntnisse</a>
    <a href="/ops" class="active">Ops</a>
  </nav>

  <main class="main">
    <div class="page-header">
      <% if (locals.allowJobFallback) { %>
        <h1>Ops Viewer</h1>
        <p class="subtitle">Git-Health-Audit und Reparatur-Routinen (Job-Fallback aktiviert).</p>
      <% } else { %>
        <h1>Ops Viewer</h1>
        <p class="subtitle">Git-Health-Audit und Reparatur-Routinen (Read-only).</p>
      <% } %>
    </div>

    <% if (!locals.acsUrl) { %>
      <div class="not-configured" data-testid="ops-not-configured">
        <h2>Ops Viewer Not Configured</h2>
        <p>The agent-control-surface (acs) URL is not set.</p>
        <p>Please configure <code>LEITSTAND_ACS_URL</code>.</p>
      </div>
    <% } else { %>
      <div class="section" data-testid="ops-panel">
        <!-- Server-injected configuration data -->
        <div id="ops-config-data" style="display: none;"
             data-acs-url="<%= locals.acsUrl %>"
             data-allow-job-fallback="<%= locals.allowJobFallback || false %>"
             data-acs-viewer-token="<%= locals.acsViewerToken || '' %>">
        </div>

        <!-- Error container for inline diagnostics -->
        <div id="errorContainer"></div>

        <div class="header">
          <div>
            <strong style="display: block; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 8px;">Repository</strong>
            <select id="repoSelect">
              <% locals.configuredRepos.forEach(function(repo) { %>
                <option value="<%= repo %>"><%= repo %></option>
              <% }); %>
            </select>
          </div>
          <div style="display: flex; align-items: center; gap: 12px;">
            <span id="pollIndicator" class="poll-indicator">Waiting for job…</span>
            <button id="runAuditBtn">
              <% if (locals.allowJobFallback) { %>
                Refresh (may create job)
              <% } else { %>
                Refresh View
              <% } %>
            </button>
          </div>
        </div>

        <div class="acs-info">
          Data source: <strong>agent-control-surface (<%= locals.acsUrl %>)</strong>
          <% if (locals.acsViewerToken) { %>
            <span style="margin-left: 8px; color: var(--accent);" title="Optional token configured (sent, not strictly enforced by default)">🔒</span>
          <% } %>
          <br/>
          <span style="color: var(--text-muted); font-size: 0.85em; display: block; margin-top: 6px;">
            <% if (locals.allowJobFallback) { %>
              Sync fetch preferred; Job triggers enabled as fallback (may POST /api/audit/git).
            <% } else { %>
              Viewer-only mode. No job triggers.
            <% } %>
          </span>
        </div>

        <div id="auditResult" style="display: none;">
          <div id="statusSummary" style="margin-bottom: 16px; font-size: 1.2em; font-weight: 600;"></div>

          <details open style="margin-bottom: 20px;">
            <summary style="cursor: pointer; color: var(--text-primary); font-weight: 500; padding: 8px; margin: -8px;">Audit Artifact (JSON)</summary>
            <pre id="auditJson" style="margin-top: 12px;"></pre>
          </details>

          <div id="routinesSection" style="display: none;">
            <div class="section-title">Suggested Repair Routines</div>
            <p style="color: var(--text-secondary); font-size: 0.9em; margin-bottom: 16px;">
              ⚠️ Leitstand is a viewer. To apply routines, use the agent-control-surface.
            </p>
            <div id="routinesList"></div>
          </div>
        </div>
      </div>
    <% } %>
  </main>

  <% if (locals.acsUrl) { %>
  <script>
    const repoSelect = document.getElementById('repoSelect');
    const runAuditBtn = document.getElementById('runAuditBtn');
    const pollIndicator = document.getElementById('pollIndicator');
    const auditResult = document.getElementById('auditResult');
    const auditJson = document.getElementById('auditJson');
    const statusSummary = document.getElementById('statusSummary');
    const routinesSection = document.getElementById('routinesSection');
    const routinesList = document.getElementById('routinesList');
    const errorContainer = document.getElementById('errorContainer');

    const opsConfigData = document.getElementById('ops-config-data').dataset;
    const ACS_URL = opsConfigData.acsUrl;
    const ALLOW_JOB_FALLBACK = opsConfigData.allowJobFallback === 'true';
    const ACS_VIEWER_TOKEN = opsConfigData.acsViewerToken || null;

    const POLL_INTERVAL = 1000;
    const MAX_POLLS = 30;

    let currentAudit = null;

    function getAuthHeaders() {
      const headers = {};
      if (ACS_VIEWER_TOKEN) headers['X-ACS-Viewer-Token'] = ACS_VIEWER_TOKEN;
      return headers;
    }

    runAuditBtn.addEventListener('click', async () => {
      if (window.location.protocol === 'https:' && ACS_URL.startsWith('http:')) {
        showError("Mixed Content Blocked: Leitstand is HTTPS but acs is HTTP.\n\nConfigure acs to use HTTPS or deploy behind a secure proxy.");
        return;
      }

      const repo = repoSelect.value;
      startLoading();
      clearError();

      try {
        let res = await fetch(`${ACS_URL}/api/audit/git/sync?repo=${encodeURIComponent(repo)}`, {
          method: 'GET',
          headers: getAuthHeaders()
        });

        if (res.status === 404 || res.status === 405 || res.status === 501) {
          if (ALLOW_JOB_FALLBACK) {
            res = await fetch(`${ACS_URL}/api/audit/git?repo=${encodeURIComponent(repo)}`, {
              method: 'POST',
              headers: getAuthHeaders()
            });
          } else {
            throw new Error(`Sync endpoint unavailable (${res.status}) and Job Fallback is disabled.`);
          }
        }

        if (!res.ok) throw new Error(`acs Error: HTTP ${res.status}`);

        const initialData = await res.json();

        if (res.status === 202 && initialData.job_id) {
          pollIndicator.style.display = 'inline';
          pollIndicator.textContent = `Job queued (${initialData.job_id})…`;
          await pollJob(initialData.job_id);
        } else if (initialData.kind === 'audit.git') {
          renderAudit(initialData);
        } else {
          throw new Error("Unknown response format from acs.");
        }
      } catch (e) {
        handleError(e);
      } finally {
        stopLoading();
      }
    });

    async function pollJob(jobId) {
      let attempts = 0;
      const MAX_FAILURES = 3;
      let consecutiveFailures = 0;

      while (attempts < MAX_POLLS) {
        attempts++;
        await new Promise(r => setTimeout(r, POLL_INTERVAL));

        try {
          const res = await fetch(`${ACS_URL}/api/jobs/${jobId}`, {
            headers: getAuthHeaders()
          });
          if (!res.ok) {
            consecutiveFailures++;
            pollIndicator.textContent = `Job status fetch failed (HTTP ${res.status}), retrying… (${consecutiveFailures}/${MAX_FAILURES})`;
            if (consecutiveFailures >= MAX_FAILURES) {
              throw new Error("Polling failed: acs returned errors multiple times.");
            }
            continue;
          }

          consecutiveFailures = 0;

          const job = await res.json();

          if (job.status === 'done') {
            let audit = null;
            if (Array.isArray(job.results)) {
              const item = job.results.find(r => r.audit && r.audit.kind === 'audit.git');
              if (item) audit = item.audit;
            } else if (job.result && job.result.audit && job.result.audit.kind === 'audit.git') {
              audit = job.result.audit;
            }

            if (audit) {
              renderAudit(audit);
              pollIndicator.style.display = 'none';
              return;
            } else {
              throw new Error("Job completed but no audit artifact found.");
            }
          } else if (job.status === 'error') {
            pollIndicator.style.display = 'none';
            throw new Error(`Job failed: ${job.error || 'Unknown error'}`);
          } else if (job.status === 'queued' || job.status === 'running') {
            pollIndicator.textContent = `Job ${job.status}… (${attempts}/${MAX_POLLS})`;
          } else {
            throw new Error(`Unknown job status '${job.status}'.`);
          }
        } catch (pollErr) {
          if (pollErr.message && pollErr.message.includes('Polling failed:')) {
            throw pollErr;
          }
          consecutiveFailures++;
          if (consecutiveFailures >= MAX_FAILURES) {
            throw new Error("Polling failed: Exception multiple times in a row.");
          }
        }
      }
      pollIndicator.style.display = 'none';
      throw new Error("Polling timed out. Please check acs logs or try again.");
    }

    function startLoading() {
      runAuditBtn.disabled = true;
      runAuditBtn.textContent = ALLOW_JOB_FALLBACK ? 'Fetching (may create job)…' : 'Fetching from acs…';
      auditResult.style.display = 'none';
      routinesSection.style.display = 'none';
      pollIndicator.style.display = 'none';
    }

    function stopLoading() {
      runAuditBtn.disabled = false;
      runAuditBtn.textContent = ALLOW_JOB_FALLBACK ? 'Refresh (may create job)' : 'Refresh View';
    }

    function showError(msg) {
      errorContainer.className = 'error-box';
      errorContainer.textContent = msg;
      errorContainer.style.display = 'block';
    }

    function clearError() {
      errorContainer.className = '';
      errorContainer.style.display = 'none';
      errorContainer.textContent = '';
    }

    function handleError(e) {
      console.error(e);
      let msg = e.toString();
      const isMixedContent = window.location.protocol === 'https:' && ACS_URL.startsWith('http:');

      if (msg.includes('Failed to fetch') || msg.includes('NetworkError')) {
        msg += '\n\nLikely Causes:';
        if (isMixedContent) {
          msg += '\n- Mixed Content: Leitstand is HTTPS but acs is HTTP.';
        } else {
          msg += '\n- acs is not running at ' + ACS_URL;
          msg += '\n- CORS is blocked.';
        }
      }
      pollIndicator.style.display = 'none';
      showError(msg);
    }

    function renderAudit(data) {
      if (data.kind !== 'audit.git') {
        showError('Received invalid data format (expected audit.git).');
        return;
      }

      currentAudit = data;
      auditResult.style.display = 'block';
      auditJson.textContent = JSON.stringify(data, null, 2);

      statusSummary.className = `status-${data.status}`;
      statusSummary.textContent = `Status: ${data.status.toUpperCase()}`;

      routinesList.innerHTML = '';
      if (data.suggested_routines && data.suggested_routines.length > 0) {
        routinesSection.style.display = 'block';
        data.suggested_routines.forEach(routine => {
          const card = document.createElement('div');
          card.className = 'routine-card';

          let riskColor = '--fail';
          if (routine.risk === 'low') riskColor = '--ok';
          if (routine.risk === 'medium') riskColor = '--warn';

          const headerDiv = document.createElement('div');
          headerDiv.className = 'routine-header';

          const idSpan = document.createElement('span');
          idSpan.textContent = routine.id;

          const riskSpan = document.createElement('span');
          riskSpan.style.color = `var(${riskColor})`;
          riskSpan.textContent = `Risk: ${routine.risk}`;

          headerDiv.appendChild(idSpan);
          headerDiv.appendChild(riskSpan);

          const reasonP = document.createElement('p');
          reasonP.textContent = routine.reason;
          reasonP.style.marginTop = '8px';
          reasonP.style.color = 'var(--text-secondary)';
          reasonP.style.fontSize = '0.9em';

          const actionsDiv = document.createElement('div');
          actionsDiv.className = 'routine-actions';

          const actionLabel = document.createElement('span');
          actionLabel.style.color = 'var(--text-secondary)';
          actionLabel.style.fontSize = '0.85em';
          actionLabel.textContent = 'Action: ';

          const acsLink = document.createElement('a');
          acsLink.href = `${ACS_URL}/`;
          acsLink.className = 'acs-link';
          acsLink.target = '_blank';
          acsLink.rel = 'noopener noreferrer';
          acsLink.textContent = 'Open acs →';

          actionsDiv.appendChild(actionLabel);
          actionsDiv.appendChild(acsLink);

          card.appendChild(headerDiv);
          card.appendChild(reasonP);
          card.appendChild(actionsDiv);
          routinesList.appendChild(card);
        });
      }
    }
  </script>
  <% } %>
</body>
</html>
