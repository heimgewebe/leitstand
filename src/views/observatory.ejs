<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Leitstand Observatory - System Observation and Insights Dashboard">
  <title>Observatorium - Leitstand</title>
  <style>
    :root {
      --bg-primary: #0a0e1a;
      --bg-secondary: #111827;
      --bg-card: rgba(17, 24, 39, 0.85);
      --bg-glass: rgba(255, 255, 255, 0.04);
      --border-glass: rgba(255, 255, 255, 0.08);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --accent: #3b82f6;
      --ok: #22c55e;
      --warn: #f59e0b;
      --fail: #ef4444;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      width: 100%;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
      background-color: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* Main Container */
    .main-wrapper {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 20px 40px 20px;
    }

    /* Page Title */
    h1 {
      font-size: 2.5em;
      margin-bottom: 30px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    h2 {
      font-size: 1.5em;
      margin: 30px 0 20px 0;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    h3 {
      font-size: 1.1em;
      margin: 15px 0 10px 0;
      font-weight: 600;
    }

    h4 {
      font-size: 1em;
      margin: 10px 0 5px 0;
      font-weight: 600;
    }

    /* Section Cards */
    .section {
      background-color: var(--bg-card);
      border: 1px solid var(--border-glass);
      border-radius: 12px;
      backdrop-filter: blur(16px);
      padding: 20px;
      margin-bottom: 20px;
    }

    .section-alt {
      background-color: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 12px;
      backdrop-filter: blur(10px);
      padding: 16px;
      margin-bottom: 20px;
      font-size: 0.9em;
    }

    /* Metadata Display */
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
      font-size: 0.95em;
    }

    .meta-item {
      display: flex;
      flex-direction: column;
    }

    .meta-label {
      color: var(--text-muted);
      font-size: 0.85em;
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .meta-value {
      color: var(--text-primary);
      font-weight: 500;
      word-break: break-word;
    }

    /* Status Badges */
    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 6px;
      font-size: 0.85em;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .status-ok {
      background-color: rgba(34, 197, 94, 0.15);
      color: var(--ok);
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .status-warn {
      background-color: rgba(245, 158, 11, 0.15);
      color: var(--warn);
      border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .status-fail {
      background-color: rgba(239, 68, 68, 0.15);
      color: var(--fail);
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .status-unclear {
      background-color: rgba(168, 85, 247, 0.15);
      color: #a855f7;
      border: 1px solid rgba(168, 85, 247, 0.3);
    }

    .status-missing {
      background-color: rgba(148, 163, 184, 0.15);
      color: var(--text-secondary);
      border: 1px solid rgba(148, 163, 184, 0.3);
    }

    /* Alert Boxes */
    .alert-warning {
      background-color: rgba(245, 158, 11, 0.1);
      border: 1px solid rgba(245, 158, 11, 0.3);
      border-left: 4px solid var(--warn);
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 15px;
      font-size: 0.95em;
    }

    .alert-error {
      background-color: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
      border-left: 4px solid var(--fail);
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 15px;
      font-size: 0.95em;
    }

    .alert-info {
      background-color: rgba(59, 130, 246, 0.1);
      border: 1px solid rgba(59, 130, 246, 0.3);
      border-left: 4px solid var(--accent);
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 15px;
      font-size: 0.95em;
    }

    /* Tables */
    table {
      width: 100%;
      border-collapse: collapse;
      background-color: var(--bg-secondary);
      border-radius: 8px;
      overflow: hidden;
      font-size: 0.95em;
    }

    thead {
      background-color: var(--bg-glass);
      border-bottom: 1px solid var(--border-glass);
    }

    th {
      padding: 12px;
      text-align: left;
      color: var(--text-secondary);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.85em;
    }

    td {
      padding: 12px;
      border-bottom: 1px solid var(--border-glass);
      color: var(--text-primary);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    tbody tr:hover {
      background-color: var(--bg-glass);
    }

    /* Metric Cards */
    .metric-card {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border-glass);
      border-radius: 8px;
      padding: 15px;
      text-align: center;
    }

    .metric-value {
      font-size: 2em;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .metric-label {
      color: var(--text-secondary);
      font-size: 0.85em;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
      gap: 12px;
      margin: 15px 0;
    }

    /* Lists */
    ul, ol {
      margin-left: 20px;
    }

    li {
      margin-bottom: 6px;
      color: var(--text-primary);
    }

    /* Code/Monospace */
    code, pre {
      font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace;
      background-color: var(--bg-secondary);
      color: var(--text-primary);
      border-radius: 6px;
      padding: 2px 6px;
    }

    pre {
      padding: 12px;
      overflow-x: auto;
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid var(--border-glass);
    }

    /* Links */
    a {
      color: var(--accent);
      text-decoration: none;
      transition: opacity 0.2s ease;
    }

    a:hover {
      opacity: 0.8;
      text-decoration: underline;
    }

    /* Insight/Negation Cards */
    .insight-card {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border-glass);
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 12px;
    }

    .insight-card.negation {
      border-left: 4px solid var(--fail);
      background-color: rgba(239, 68, 68, 0.05);
    }

    .insight-meta {
      font-size: 0.85em;
      color: var(--text-muted);
      margin: 8px 0;
    }

    .verdict {
      font-weight: 600;
      color: var(--fail);
      margin-top: 8px;
    }

    .relation {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
      font-size: 0.9em;
    }

    .relation-item {
      background-color: var(--bg-glass);
      padding: 4px 10px;
      border-radius: 4px;
      border: 1px solid var(--border-glass);
      color: var(--text-secondary);
    }

    /* Empty State */
    .empty-state {
      background-color: var(--bg-card);
      border: 2px dashed var(--border-glass);
      border-radius: 12px;
      padding: 40px 20px;
      text-align: center;
      color: var(--text-secondary);
    }

    .empty-state h3 {
      margin-top: 0;
      color: var(--text-primary);
    }

    .empty-state p {
      margin-bottom: 12px;
    }

    /* Debug Section */
    .debug-section {
      background-color: var(--bg-secondary);
      border: 1px solid rgba(59, 130, 246, 0.3);
      border-left: 4px solid var(--accent);
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 20px;
      font-size: 0.9em;
    }

    .debug-section h3 {
      margin-top: 0;
      color: var(--accent);
    }

    .debug-section p {
      color: var(--text-secondary);
      font-size: 0.9em;
      margin: 8px 0;
    }

    /* Topic Cards */
    .topic-card {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border-glass);
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 12px;
    }

    .topic-card h3 {
      margin-top: 0;
    }

    .topic-card p {
      margin: 8px 0;
      font-size: 0.95em;
    }

    /* Responsive */
    @media (max-width: 768px) {
      h1 {
        font-size: 1.8em;
      }

      h2 {
        font-size: 1.3em;
      }

      .meta-grid {
        grid-template-columns: 1fr;
      }

      .metric-grid {
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
      }

      .main-wrapper {
        padding: 0 12px 30px 12px;
      }

    }
  </style>
  <link rel="stylesheet" href="/assets/shell.css">
  <script type="module" src="/assets/shell.mjs"></script>
</head>
<body>
  <%- include('_nav') %>

  <div class="main-wrapper">
    <h1>Observatorium</h1>

    <!-- STRICT MODE & FORENSICS -->
    <div class="section-alt">
      <div style="margin-bottom: 10px;">
        <strong>Strict Mode:</strong>
        <% if (locals.view_meta && locals.view_meta.is_strict) { %>
            <span class="status-badge status-fail">ON</span>
        <% } else { %>
            <span class="status-badge status-ok">OFF</span>
        <% } %>
      </div>
      <% if (locals.view_meta && locals.view_meta.forensics) { %>
        <div style="margin-top: 10px; border-top: 1px solid var(--border-glass); padding-top: 10px;">
          <div style="margin-bottom: 8px;"><strong>Forensics Metadata:</strong></div>
          <% if (locals.view_meta.forensics.fetched_at) { %>
             <div style="color: var(--text-secondary); font-size: 0.9em;">Global: <%= locals.view_meta.forensics.fetched_at %></div>
          <% } %>
          <% if (locals.view_meta.forensics.observatory) { %>
             <div style="color: var(--text-secondary); font-size: 0.9em; margin-top: 6px;">
               <strong>Observatory:</strong>
               <% if (locals.view_meta.forensics.observatory.fetched_at) { %>
                  <%= locals.view_meta.forensics.observatory.fetched_at %> |
               <% } %>
               <%= locals.view_meta.forensics.observatory.bytes %> bytes |
               Source: <%= locals.view_meta.forensics.observatory.source_url %>
               <% if (locals.view_meta.forensics.observatory.sha) { %> | SHA: <code title="<%= locals.view_meta.forensics.observatory.sha %>"><%= locals.view_meta.forensics.observatory.sha.substring(0, 7) %>...</code><% } %>
               <% if (locals.view_meta.forensics.observatory.schema_ref) { %> | <a href="<%= locals.view_meta.forensics.observatory.schema_ref %>" target="_blank" rel="noopener noreferrer">Schema ref</a><% } %>
             </div>
          <% } %>
          <% if (locals.view_meta.forensics.integrity) { %>
             <div style="color: var(--text-secondary); font-size: 0.9em; margin-top: 6px;">
               <strong>Integrity:</strong>
               <% if (locals.view_meta.forensics.integrity.fetched_at) { %>
                  <%= locals.view_meta.forensics.integrity.fetched_at %>
               <% } %>
             </div>
          <% } %>
          <% if (locals.view_meta.forensics.plexer_report) { %>
             <div style="color: var(--text-secondary); font-size: 0.9em; margin-top: 6px;">
               <strong>Plexer:</strong>
               <% if (locals.view_meta.forensics.plexer_report.fetched_at) { %>
                  <%= locals.view_meta.forensics.plexer_report.fetched_at %>
               <% } %>
             </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- RUNTIME DEBUG -->
    <div id="runtime-observatory" style="display: none;">
      <div class="debug-section">
        <h3>Runtime Fetch Status</h3>
        <p style="margin-top: 0;">Checks connectivity to upstream Release Asset. Does <strong>not</strong> verify local build artifacts.</p>
        <div id="obs-runtime-status" style="margin-top: 10px; color: var(--text-secondary);">Initializing...</div>
        <pre id="obs-runtime-json"></pre>
      </div>
    </div>

    <script>
      (async function() {
        const URL = "<%= locals.observatoryUrl %>";
        const debugContainer = document.getElementById("runtime-observatory");
        const statusEl = document.getElementById("obs-runtime-status");
        const preEl = document.getElementById("obs-runtime-json");

        const isDebug = new URLSearchParams(window.location.search).get("debug") === "1";
        if (isDebug) debugContainer.style.display = "block";

        statusEl.textContent = "Fetching live data from: " + URL;

        try {
          const r = await fetch(URL, { cache: "no-store" });
          if (!r.ok) throw new Error("HTTP " + r.status);
          const data = await r.json();

          // Update Metadata
          const genEl = document.getElementById("obs-generated-at");
          if (genEl) genEl.textContent = (data.generated_at || "n/a") + " (Live)";
          const srcEl = document.getElementById("obs-source-desc");
          if (srcEl) srcEl.textContent = "Live from Release Asset";

          // Update Topics
          const topicsContainer = document.getElementById("obs-topics-container");
          if (topicsContainer) {
            topicsContainer.textContent = "";
            if (data.topics && Array.isArray(data.topics) && data.topics.length > 0) {
              data.topics.forEach(t => {
                const topicDiv = document.createElement("div");
                topicDiv.className = "topic-card";
                const h3 = document.createElement("h3");
                h3.textContent = t.title || "Untitled topic";
                topicDiv.appendChild(h3);
                if (t.summary) {
                  const pSummary = document.createElement("p");
                  pSummary.textContent = t.summary;
                  topicDiv.appendChild(pSummary);
                }
                const pSources = document.createElement("p");
                const strong = document.createElement("strong");
                strong.textContent = "Sources: ";
                pSources.appendChild(strong);
                pSources.appendChild(document.createTextNode(String(t.sources ? t.sources.length : 0)));
                topicDiv.appendChild(pSources);
                topicsContainer.appendChild(topicDiv);
              });
            } else {
              const p = document.createElement("p");
              p.textContent = "No topics available.";
              topicsContainer.appendChild(p);
            }
          }

          // Debug Output
          statusEl.textContent = "";
          const strong = document.createElement("strong");
          strong.textContent = "Live data loaded!";
          statusEl.appendChild(strong);
          statusEl.style.color = "var(--ok)";
          if (isDebug) {
            preEl.textContent = JSON.stringify(data, null, 2);
          }
        } catch (e) {
          statusEl.textContent = "";
          statusEl.style.color = "var(--fail)";

          const strong = document.createElement("strong");
          strong.textContent = "Runtime fetch failed.";
          statusEl.appendChild(strong);
          statusEl.appendChild(document.createTextNode(" "));
          statusEl.appendChild(document.createTextNode(String(e)));

          if (isDebug) console.error("Observatory Runtime Fetch Error:", e);
        }
      })();
    </script>

    <% if (data) { %>

    <!-- METADATA SECTION -->
    <div class="section">
      <h2>Data Source & Metadata</h2>
      <div class="meta-grid">
        <div class="meta-item">
          <span class="meta-label">Generated</span>
          <span class="meta-value" id="obs-generated-at"><%= data.generated_at || "n/a" %></span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Observatory ID</span>
          <span class="meta-value"><%= data.observatory_id || "n/a" %></span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Source</span>
          <span class="meta-value" id="obs-source-desc">
            <% if (typeof data.source === 'string') { %>
              <%= data.source %>
            <% } else if (data.source && typeof data.source === 'object') { %>
              <%= data.source.source_type %>: <%= data.source.ref %>
            <% } else { %>
              n/a
            <% } %>
          </span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Source Kind</span>
          <% if (locals.view_meta && locals.view_meta.source_kind === 'artifact') { %>
            <span class="status-badge status-ok">Artifact</span>
          <% } else if (locals.view_meta && locals.view_meta.source_kind === 'fixture') { %>
            <span class="status-badge status-warn">Fixture (Fallback)</span>
          <% } else { %>
            <span class="status-badge status-unclear">Unknown</span>
          <% } %>
        </div>
      </div>

      <% if (locals.view_meta && locals.view_meta.source_kind === 'fixture') { %>
        <div class="alert-warning">
          <strong>⚠️ Fallback Mode:</strong> This view is running in fallback mode using static fixture data. The live knowledge artifact could not be loaded.
        </div>
      <% } %>
    </div>
    <!-- HEIMGEIST SELF-STATE PANEL -->
    <div class="section">
      <h2>Heimgeist Self-State</h2>
      <% if (locals.selfState && locals.selfState.current) { %>
        <div style="margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
          <div>
            <strong>Source:</strong>
            <% if (locals.view_meta && locals.view_meta.self_state_source_kind === 'artifact') { %>
              <span class="status-badge status-ok">self_state.json (Artifact)</span>
            <% } else { %>
              <span class="status-badge status-warn">self_state.json (Fixture)</span>
            <% } %>
            <% if (locals.selfState.schema) { %>
              <span style="color: var(--text-muted); font-size: 0.9em; margin-left: 8px;">(Schema: <%= locals.selfState.schema %>)</span>
            <% } else { %>
              <span style="color: var(--fail); font-size: 0.9em; margin-left: 8px;">(Schema: unknown)</span>
            <% } %>
          </div>
          <div style="font-weight: 600; padding: 6px 12px; border-radius: 6px; background-color: rgba(168, 85, 247, 0.15); color: #a855f7; border: 1px solid rgba(168, 85, 247, 0.3);">
            Autonomy: <%= locals.selfState.current.autonomy_level %>
          </div>
        </div>

        <% if (locals.view_meta && locals.view_meta.self_state_schema_valid === false) { %>
          <div class="alert-warning">
            <strong>⚠️ Schema Mismatch:</strong> The loaded artifact does not match the expected contract (heimgeist.self_state.bundle.v1). Displaying best-effort rendering.
          </div>
        <% } %>

        <!-- Current Metrics -->
        <div class="metric-grid">
          <div class="metric-card">
            <div class="metric-value" style="color: #a855f7;"><%= (locals.selfState.current.confidence * 100).toFixed(0) %>%</div>
            <div class="metric-label">Confidence</div>
          </div>
          <div class="metric-card">
            <div class="metric-value" style="color: #a855f7;"><%= (locals.selfState.current.fatigue * 100).toFixed(0) %>%</div>
            <div class="metric-label">Fatigue</div>
          </div>
          <div class="metric-card">
            <div class="metric-value" style="color: #a855f7;"><%= (locals.selfState.current.risk_tension * 100).toFixed(0) %>%</div>
            <div class="metric-label">Risk Tension</div>
          </div>
        </div>

        <!-- Basis Signals -->
        <% if (locals.selfState.current.basis_signals && locals.selfState.current.basis_signals.length > 0) { %>
          <div style="margin-top: 20px;">
            <strong>Basis Signals:</strong>
            <ul style="margin-top: 8px; color: var(--text-secondary);">
              <% locals.selfState.current.basis_signals.forEach(function(signal) { %>
                <li><%= signal %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <!-- History -->
        <% if (locals.selfState.history && locals.selfState.history.length > 0) { %>
          <div style="margin-top: 20px; border-top: 1px solid var(--border-glass); padding-top: 20px;">
            <strong>History (Last 7 Snapshots)</strong>
            <table style="margin-top: 12px;">
              <thead>
                <tr>
                  <th>Time</th>
                  <th>Autonomy</th>
                  <th>Conf.</th>
                  <th>Fatigue</th>
                  <th>Risk</th>
                </tr>
              </thead>
              <tbody>
                <% locals.selfState.history.slice(0, 7).forEach(function(snap) { %>
                  <%
                     let isValidDate = !isNaN(Date.parse(snap.timestamp));
                     let timeDisplay = isValidDate ? snap.timestamp : (snap.timestamp + " (INVALID)");
                  %>
                  <tr <% if (!isValidDate) { %>style="background-color: rgba(239, 68, 68, 0.1);"<% } %>>
                    <td><%= timeDisplay %></td>
                    <td><%= snap.state.autonomy_level %></td>
                    <td><%= (snap.state.confidence * 100).toFixed(0) %>%</td>
                    <td><%= (snap.state.fatigue * 100).toFixed(0) %>%</td>
                    <td><%= (snap.state.risk_tension * 100).toFixed(0) %>%</td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>

        <div style="margin-top: 20px; font-size: 0.9em; color: var(--text-muted); font-style: italic;">
          ⚠️ Self-State is heuristic – no claim to truth.
        </div>

      <% } else { %>
        <p style="color: var(--text-secondary); font-style: italic;">
          <% if (locals.view_meta && locals.view_meta.is_strict) { %>
            Self-State artifact not found (Strict Mode).
          <% } else { %>
            Self-State not available.
          <% } %>
        </p>
      <% } %>
    </div>
    <!-- PLEXER DELIVERY STATUS PANEL -->
    <div class="section">
      <h2>Plexer Delivery Status</h2>
      <% if (locals.plexerDelivery && locals.plexerDelivery.counts) { %>
        <%
           const pCounts = locals.plexerDelivery.counts;
           const pending = pCounts.pending || 0;
           const failed = pCounts.failed || 0;
           let pStatus = 'OK';
           let pStatusClass = 'status-ok';
           if (failed > 0) { pStatus = 'FAIL'; pStatusClass = 'status-fail'; }
           else if (pending > 10) { pStatus = 'BUSY'; pStatusClass = 'status-warn'; }
        %>
        <div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
          <div>
            <strong>Status:</strong>
            <span class="status-badge <%= pStatusClass %>"><%= pStatus %></span>
          </div>
          <% if (locals.plexerDelivery.last_retry_at) { %>
            <div style="font-size: 0.9em; color: var(--text-secondary);">Last Retry: <%= locals.plexerDelivery.last_retry_at %></div>
          <% } %>
        </div>

        <div class="metric-grid">
          <div class="metric-card">
            <div class="metric-value" style="color: #22c55e;"><%= pending %></div>
            <div class="metric-label">Pending</div>
          </div>
          <div class="metric-card">
            <div class="metric-value" style="color: <% if (failed > 0) { %>var(--fail)<% } else { %>#22c55e<% } %>;"><%= failed %></div>
            <div class="metric-label">Failed</div>
          </div>
        </div>

        <% if (locals.plexerDelivery.last_error) { %>
          <div class="alert-error">
            <strong>Last Error:</strong> <%= locals.plexerDelivery.last_error %>
          </div>
        <% } %>
      <% } else { %>
        <p style="color: var(--text-secondary); font-style: italic;">No delivery metrics available.</p>
      <% } %>
    </div>
    <!-- SYSTEM INTEGRITY PANEL -->
    <div class="section">
      <h2>System Integrity</h2>
      <% if (locals.integritySummaries && locals.integritySummaries.length > 0) { %>
        <%
          const reposMap = new Map();

          if (locals.fleetMetrics && locals.fleetMetrics.repos) {
            locals.fleetMetrics.repos.forEach(r => {
              if (typeof r === 'string') {
                reposMap.set(r, { name: r, status: 'MISSING', isMissing: true });
              } else if (r.name) {
                reposMap.set(r.name, { name: r.name, status: 'MISSING', isMissing: true });
              }
            });
          }

          locals.integritySummaries.forEach(s => {
            if (s.repo) {
              reposMap.set(s.repo, { ...s, isMissing: false });
            }
          });

          const repoList = Array.from(reposMap.values()).sort((a, b) => {
            const nameA = a.name || a.repo || 'unknown';
            const nameB = b.name || b.repo || 'unknown';
            return nameA.localeCompare(nameB);
          });

          let aggGap = 0;
          let aggClaims = 0;
          let aggArtifacts = 0;
          let statusRank = 0; // 0=OK, 1=UNCLEAR, 2=WARN, 3=GAP, 4=FAIL

          repoList.forEach(s => {
            aggGap += (s.counts?.loop_gaps || 0);
            aggClaims += (s.counts?.claims || 0);
            aggArtifacts += (s.counts?.artifacts || 0);

            let st = (s.status || 'OK').toUpperCase();
            if (s.isMissing) st = 'MISSING';

            let rank = 0;
            if (st === 'UNCLEAR') rank = 1;
            else if (st === 'WARN') rank = 2;
            else if (st === 'GAP') rank = 3;
            else if (st === 'MISSING') rank = 4;
            else if (st === 'FAIL') rank = 4;

            if (rank > statusRank) statusRank = rank;
          });

          let aggStatus = 'OK';
          let aggStatusClass = 'status-ok';

          if (statusRank === 4) {
            aggStatus = 'FAIL';
            aggStatusClass = 'status-fail';
          } else if (statusRank === 3) {
            aggStatus = 'GAP';
            aggStatusClass = 'status-fail';
          } else if (statusRank === 2) {
            const hasWarn = repoList.some(r => (r.status||'').toUpperCase() === 'WARN');
            if (hasWarn) {
              aggStatus = 'WARN';
              aggStatusClass = 'status-warn';
            } else {
              aggStatus = 'WARN';
              aggStatusClass = 'status-warn';
            }
          } else if (statusRank === 1) {
            aggStatus = 'UNCLEAR';
            aggStatusClass = 'status-unclear';
          }
        %>

        <div style="margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
          <div>
            <strong>Source:</strong>
            <% if (locals.view_meta && locals.view_meta.integrity_source_kind === 'artifact') { %>
              <span class="status-badge status-ok">integrity/*.json (Artifact)</span>
            <% } else { %>
              <span class="status-badge status-warn">integrity/*.json (Fixture)</span>
            <% } %>
          </div>
          <div style="font-weight: 600;">
            <span class="status-badge <%= aggStatusClass %>">Overall: <%= aggStatus %></span>
          </div>
        </div>

        <% if (locals.view_meta && locals.view_meta.forensics && locals.view_meta.forensics.integrity && locals.view_meta.forensics.integrity.error_reason) { %>
          <div class="alert-warning">
            <strong>⚠️ Last Fetch Error:</strong> <%= locals.view_meta.forensics.integrity.error_reason %>
          </div>
        <% } %>

        <!-- Repo Table -->
        <table style="margin-top: 15px;">
          <thead>
            <tr>
              <th>Repo</th>
              <th>Status</th>
              <th>Counts / Details</th>
              <th>Generated At</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <%
              repoList.forEach(function(s) {
                s.name = s.name || s.repo || 'unknown';

                let status = s.status || 'UNCLEAR';
                let statusClass = 'status-unclear';
                let statusTooltip = '';
                const isSanitized = s.generated_at_sanitized === true || (s.payload && s.payload.generated_at_sanitized === true);

                if (isSanitized) {
                  statusTooltip = (statusTooltip ? statusTooltip + '. ' : '') + 'Timestamp sanitized by Chronik';
                }
                if (!s.generated_at) {
                  statusTooltip = (statusTooltip ? statusTooltip + '. ' : '') + 'Missing timestamp';
                }

                if (s.isMissing) {
                  status = 'MISSING';
                  statusClass = 'status-missing';
                  statusTooltip = 'Report not reachable';
                } else {
                  if (status === 'OK') {
                    statusClass = 'status-ok';
                  } else if (status === 'WARN') {
                    statusClass = 'status-warn';
                  } else if (status === 'UNCLEAR') {
                    statusClass = 'status-unclear';
                  } else if (status === 'FAIL' || status === 'GAP') {
                    statusClass = 'status-fail';
                    if (!s.generated_at || isNaN(Date.parse(s.generated_at))) {
                      statusTooltip = 'Invalid or missing timestamp';
                    } else {
                      statusTooltip = statusTooltip || 'Schema violation';
                    }
                  }
                }
            %>
            <tr>
              <td style="font-weight: 600;">
                <% if (s.name === 'unknown') { %>
                  <span title="Repo name missing in artifact" style="color: var(--fail); border-bottom: 1px dotted var(--fail); cursor: help;">unknown</span>
                <% } else { %>
                  <%= s.name %>
                <% } %>
              </td>
              <td>
                <span class="status-badge <%= statusClass %>" <% if (statusTooltip) { %>title="<%= statusTooltip %>"<% } %>>
                  <%= status %>
                </span>
              </td>
              <td style="font-size: 0.9em;">
                <% if (s.counts && typeof s.counts === 'object') { %>
                  <% Object.keys(s.counts).sort().forEach(function(key, index, arr) { %>
                    <span style="white-space: nowrap;">
                      <%= key %>: <strong><%= s.counts[key] %></strong><%= index < arr.length - 1 ? ', ' : '' %>
                    </span>
                  <% }); %>
                <% } else { %>
                  <% if (status === 'OK') { %>
                    <span style="color: var(--warn); font-style: italic; border-bottom: 1px dotted var(--warn); cursor: help;" title="Artifact missing counts field">(missing)</span>
                  <% } else { %>
                    <span style="color: var(--text-muted); font-style: italic;" title="fetch failed or report invalid">(unavailable)</span>
                  <% } %>
                <% } %>
              </td>
              <td style="font-size: 0.9em;">
                <%= s.generated_at || '—' %>
                <% if (isSanitized) { %>
                  <div style="color: var(--warn); font-size: 0.85em; margin-top: 4px;">⚠️ Chronik-Eingriff</div>
                <% } %>
              </td>
              <td style="text-align: right;">
                <% if (s.summary_url) { %>
                  <a href="<%= s.summary_url %>" target="_blank" rel="noopener noreferrer" title="View detailed report">→</a>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>

        <!-- Aggregated Metrics -->
        <div class="metric-grid" style="margin-top: 20px;">
          <div class="metric-card">
            <div class="metric-value"><%= aggClaims %></div>
            <div class="metric-label">Total Claims</div>
          </div>
          <div class="metric-card">
            <div class="metric-value"><%= aggArtifacts %></div>
            <div class="metric-label">Total Artifacts</div>
          </div>
          <div class="metric-card">
            <div class="metric-value" style="color: var(--fail);"><%= aggGap %></div>
            <div class="metric-label">Total Gaps</div>
          </div>
        </div>

      <% } else { %>
        <div style="margin-bottom: 15px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
          <div>
            <strong>Source:</strong>
            <span class="status-badge status-missing">MISSING</span>
          </div>
        </div>
        <p style="color: var(--text-secondary); font-style: italic;">
          <% if (locals.view_meta && locals.view_meta.is_strict) { %>
            Integrity summary not found (Strict Mode).
          <% } else { %>
            Integrity summary not found.
          <% } %>
        </p>
      <% } %>
    </div>
    <!-- PUBLISHED KNOWLEDGE SECTION -->
    <div class="section">
      <h2>Verdichtete Erkenntnis (Published Daily)</h2>
      <% if (locals.insightsDaily) { %>
        <div class="meta-grid" style="margin-bottom: 15px;">
          <div class="meta-item">
            <span class="meta-label">Source</span>
            <% if (locals.view_meta && locals.view_meta.insights_source_kind === 'artifact') { %>
              <span class="status-badge status-ok">insights.daily.json (Artifact)</span>
            <% } else { %>
              <span class="status-badge status-warn">insights.daily.json (Fixture)</span>
            <% } %>
          </div>
          <div class="meta-item">
            <span class="meta-label">Date</span>
            <span class="meta-value"><%= locals.insightsDaily.ts || 'n/a' %></span>
          </div>
          <% if (locals.insightsDaily.source) { %>
            <div class="meta-item">
              <span class="meta-label">Source ID</span>
              <span class="meta-value"><%= locals.insightsDaily.source %></span>
            </div>
          <% } %>
        </div>

        <% if (locals.insightsDaily.metadata) { %>
          <% if (locals.insightsDaily.metadata.generated_at) { %>
            <div style="margin-bottom: 10px; color: var(--text-secondary); font-size: 0.9em;">
              <strong>Generated:</strong> <%= locals.insightsDaily.metadata.generated_at %>
            </div>
          <% } %>
          <% if (locals.insightsDaily.metadata.observatory_ref) { %>
            <div style="margin-bottom: 10px; color: var(--text-secondary); font-size: 0.9em;">
              <strong>Observatory Ref:</strong> <%= locals.insightsDaily.metadata.observatory_ref %>
            </div>
          <% } %>
          <% if (typeof locals.insightsDaily.metadata.uncertainty !== 'undefined') { %>
            <div style="margin-bottom: 10px; color: var(--text-secondary); font-size: 0.9em;">
              <strong>Uncertainty:</strong> <%= locals.insightsDaily.metadata.uncertainty %>
            </div>
          <% } %>
        <% } %>

        <% if (locals.insightsDaily.topics && locals.insightsDaily.topics.length > 0) { %>
          <div style="margin-top: 15px;">
            <h4>Topics (Weighted)</h4>
            <ul style="margin-top: 8px;">
              <% locals.insightsDaily.topics.forEach(function(t) { %>
                <li><%= t[0] %> <span style="color: var(--text-muted); font-size: 0.9em;">(<%= t[1] %>)</span></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <% if (locals.insightsDaily.questions && locals.insightsDaily.questions.length > 0) { %>
          <div style="margin-top: 15px;">
            <h4>Open Questions</h4>
            <ul style="margin-top: 8px;">
              <% locals.insightsDaily.questions.forEach(function(q) { %>
                <li><%= q %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <% if (locals.insightsDaily.deltas && locals.insightsDaily.deltas.length > 0) { %>
          <div style="margin-top: 15px;">
            <h4>Deltas (Changes)</h4>
            <ul style="margin-top: 8px;">
              <% locals.insightsDaily.deltas.forEach(function(d) { %>
                <li><%= d %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

      <% } else { %>
        <% if (locals.view_meta && locals.view_meta.is_strict) { %>
          <p style="color: var(--fail); font-weight: 600;">No published insights available (Strict Mode - Artifact missing).</p>
        <% } else { %>
          <p style="color: var(--text-secondary); font-style: italic;">No daily insights published yet (Dev Fallback).</p>
        <% } %>
      <% } %>
    </div>

    <!-- RAW KNOWLEDGE SECTION -->
    <div class="section">
      <h2>Erkenntnisraum (Raw Observatory)</h2>

      <% if (data.insights && data.insights.length > 0) { %>
        <h3>Insights / Conflicts</h3>
        <div style="margin-top: 15px;">
          <% data.insights.forEach(function(insight) { %>
            <% if (insight.type === 'insight.negation') { %>
              <div class="insight-card negation">
                <h4>Conflict Detected</h4>
                <div class="insight-meta">ID: <code><%= insight.id %></code></div>
                <div class="verdict">Verdict: <%= insight.verdict %></div>
                <% if (insight.relation) { %>
                  <div class="relation">
                    <span class="relation-item"><strong>Thesis:</strong> <%= insight.relation.thesis %></span>
                    <span class="relation-item"><strong>Antithesis:</strong> <%= insight.relation.antithesis %></span>
                  </div>
                <% } %>
              </div>
            <% } else { %>
              <div class="insight-card">
                <h4><%= insight.type || 'Generic Insight' %></h4>
                <div class="insight-meta">ID: <code><%= insight.id %></code></div>
              </div>
            <% } %>
          <% }); %>
        </div>
      <% } %>

      <h3 style="margin-top: 25px;">Topics</h3>
      <div id="obs-topics-container" style="margin-top: 15px;">
        <% if (data.topics && data.topics.length > 0) { %>
          <% data.topics.forEach(function(topic) { %>
            <div class="topic-card">
              <h3 style="margin-top: 0;"><%= topic.title %></h3>
              <% if (topic.summary) { %>
                <p><%= topic.summary %></p>
              <% } %>
              <p><strong>Sources:</strong> <%= topic.sources ? topic.sources.length : 0 %></p>
            </div>
          <% }); %>
        <% } else { %>
          <p style="color: var(--text-secondary); font-style: italic;">No topics available.</p>
        <% } %>
      </div>
    </div>

  <% } else { %>
    <!-- EMPTY STATE -->
    <div class="empty-state">
      <h3>Leitstand: No Observation Data</h3>
      <p>
        <% if (locals.view_meta && locals.view_meta.is_strict) { %>
          Strict Mode is ON. Artifacts are missing, and fixture fallback is disabled.
        <% } else { %>
          No data available.
        <% } %>
      </p>
      <% if (locals.view_meta && locals.view_meta.missing_reason) { %>
        <p style="margin-top:10px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;">
          raw_reason: <strong><%= locals.view_meta.missing_reason %></strong>
        </p>
      <% } %>
      <% if (locals.view_meta && locals.view_meta.insights_missing_reason) { %>
        <p style="margin-top:5px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;">
          daily_reason: <strong><%= locals.view_meta.insights_missing_reason %></strong>
        </p>
      <% } %>
    </div>
  <% } %>

  </div><!-- /.main-wrapper -->
</body>
</html>
