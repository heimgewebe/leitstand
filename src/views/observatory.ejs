<!DOCTYPE html>
<html lang="de">
<head>
  <title>Observatorium – Leitstand</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Observatorium – Live-Erkenntnisse und Systemzustand aus der Heimgewebe-Analyse.">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-primary: #0a0e1a;
      --bg-secondary: #111827;
      --bg-card: rgba(17, 24, 39, 0.85);
      --bg-glass: rgba(255, 255, 255, 0.04);
      --border-glass: rgba(255, 255, 255, 0.08);
      --border-active: rgba(255, 255, 255, 0.15);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --accent: #3b82f6;
      --ok: #22c55e;
      --warn: #f59e0b;
      --fail: #ef4444;
      --unknown: #64748b;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
    }

    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 10px 20px;
      background: rgba(10, 14, 26, 0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-glass);
    }

    nav a {
      text-decoration: none;
      color: var(--text-secondary);
      font-size: 0.82em;
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 6px;
      transition: all 0.2s ease;
    }

    nav a:hover { color: var(--text-primary); background: var(--bg-glass); }
    nav a:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    nav a.active { color: var(--accent); background: rgba(59, 130, 246, 0.1); }
    nav .title { font-weight: 700; font-size: 0.9em; color: var(--text-primary); margin-right: 16px; }

    .main {
      max-width: 1080px;
      margin: 0 auto;
      padding: 48px 24px 96px;
    }

    .page-header {
      margin-bottom: 36px;
    }

    .page-header h1 {
      font-size: 1.9em;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 10px;
    }

    .page-header .subtitle {
      color: var(--text-secondary);
      font-size: 0.95em;
      max-width: 720px;
      line-height: 1.55;
    }

    .section-title {
      font-size: 0.72em;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      margin-bottom: 16px;
      margin-top: 32px;
    }

    .section {
      background: var(--bg-card);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border-glass);
      border-radius: 14px;
      padding: 22px 24px;
      margin-bottom: 20px;
    }

    .meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      padding: 16px 0;
      color: var(--text-secondary);
      font-size: 0.85em;
    }

    .meta-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .meta-item strong {
      color: var(--text-muted);
      font-size: 0.75em;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .empty-state {
      padding: 48px 24px;
      background: var(--bg-card);
      border: 1px dashed var(--border-glass);
      border-radius: 14px;
      text-align: center;
      color: var(--text-secondary);
      margin-top: 20px;
    }

    .empty-state h3 {
      font-size: 1.3em;
      color: var(--text-primary);
      margin-bottom: 12px;
    }

    /* Insights & Negations */
    .topic { 
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      padding: 18px 20px;
      border-radius: 10px;
      margin-bottom: 16px;
      transition: all 0.2s ease;
    }

    .topic:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: var(--border-active);
    }

    .topic h3 {
      margin: 0 0 10px 0;
      font-size: 1.1em;
      color: var(--text-primary);
    }

    .topic p {
      color: var(--text-secondary);
      font-size: 0.9em;
      line-height: 1.5;
      margin: 8px 0;
    }

    .insight-card {
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      padding: 18px 20px;
      border-radius: 10px;
      margin-bottom: 12px;
      transition: all 0.2s ease;
    }

    .insight-card:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: var(--border-active);
    }

    .insight-card.negation {
      border-left: 4px solid var(--fail);
      background: rgba(239, 68, 68, 0.08);
    }

    .insight-card h4 {
      margin: 0 0 8px 0;
      font-size: 0.95em;
      color: var(--text-primary);
    }

    .insight-meta {
      font-size: 0.8em;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .verdict {
      font-weight: 600;
      color: var(--fail);
      margin-top: 8px;
      font-size: 0.85em;
    }

    .relation {
      display: flex;
      gap: 10px;
      margin-top: 10px;
      font-size: 0.8em;
      flex-wrap: wrap;
    }

    .relation-item {
      background: var(--bg-glass);
      padding: 4px 10px;
      border-radius: 6px;
      border: 1px solid var(--border-glass);
      color: var(--text-secondary);
    }

    .warning-box {
      background: rgba(239, 68, 68, 0.08);
      border: 1px solid var(--border-glass);
      border-left: 4px solid var(--fail);
      padding: 14px 16px;
      border-radius: 10px;
      margin-bottom: 16px;
      color: var(--text-secondary);
      font-size: 0.9em;
    }

    pre {
      background: var(--bg-secondary);
      color: var(--text-secondary);
      padding: 12px 14px;
      border-radius: 8px;
      overflow: auto;
      font-size: 0.8em;
      border: 1px solid var(--border-glass);
      max-height: 200px;
    }
  </style>
</head>
<body>
  <nav>
    <span class="title">Leitstand</span>
    <a href="/">Home</a>
    <a href="/observatory" class="active">Observatorium</a>
    <a href="/anatomy">Anatomie</a>
    <a href="/timeline">Zeitachse</a>
    <a href="/insights">Erkenntnisse</a>
    <a href="/ops">Ops</a>
  </nav>

  <main class="main">
    <div class="page-header">
      <h1>Observatorium</h1>
      <p class="subtitle">Live-Erkenntnisse und Systemzustand aus der kontinuierlichen Heimgewebe-Analyse.</p>
    </div>

    <!-- STRICT MODE & FORENSICS -->
    <div class="section">
      <div class="section-title">Metadaten &amp; Forensics</div>
      <div class="meta">
        <div class="meta-item">
          <strong>Strict Mode</strong>
          <span><% if (locals.view_meta && locals.view_meta.is_strict) { %>ON<% } else { %>OFF<% } %></span>
        </div>
        <% if (locals.view_meta && locals.view_meta.forensics && locals.view_meta.forensics.fetched_at) { %>
          <div class="meta-item">
            <strong>Fetched (Global)</strong>
            <span><%= locals.view_meta.forensics.fetched_at %></span>
          </div>
        <% } %>
        <% if (locals.view_meta && locals.view_meta.forensics && locals.view_meta.forensics.observatory && locals.view_meta.forensics.observatory.fetched_at) { %>
          <div class="meta-item">
            <strong>Observatory Artifact</strong>
            <span><%= locals.view_meta.forensics.observatory.fetched_at %></span>
          </div>
        <% } %>
      </div>
      <% if (locals.view_meta && locals.view_meta.forensics && locals.view_meta.forensics.observatory) { %>
        <div style="margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border-glass); font-size: 0.8em; color: var(--text-secondary);">
          <div>Bytes: <%= locals.view_meta.forensics.observatory.bytes %> | Source: <%= locals.view_meta.forensics.observatory.source_url %></div>
          <% if (locals.view_meta.forensics.observatory.sha) { %>
            <div style="margin-top: 4px;">SHA: <code style="color: var(--text-muted); font-family: ui-monospace;"><%= locals.view_meta.forensics.observatory.sha.substring(0, 12) %>…</code></div>
          <% } %>
        </div>
      <% } %>
    </div>
    <!-- RUNTIME DEBUG -->
    <div id="runtime-observatory" style="display: none; margin-bottom: 20px;">
      <div class="section">
        <div class="section-title">Runtime Fetch</div>
        <p style="color: var(--text-secondary); font-size: 0.9em; margin-bottom: 12px;">Checks connectivity to upstream Release Asset.</p>
        <div id="obs-runtime-status" style="color: var(--text-secondary); font-size: 0.85em;">Initializing…</div>
        <pre id="obs-runtime-json" style="margin-top: 12px;"></pre>
      </div>
    </div>

    <script>
      (async function() {
        const URL = "<%= locals.observatoryUrl %>";
        const debugContainer = document.getElementById("runtime-observatory");
        const statusEl = document.getElementById("obs-runtime-status");
        const preEl = document.getElementById("obs-runtime-json");

        const isDebug = new URLSearchParams(window.location.search).get("debug") === "1";
        if (isDebug) debugContainer.style.display = "block";

        statusEl.textContent = "Fetching from: " + URL;

        try {
          const r = await fetch(URL, { cache: "no-store" });
          if (!r.ok) throw new Error("HTTP " + r.status);
          const data = await r.json();

          const genEl = document.getElementById("obs-generated-at");
          if (genEl) genEl.textContent = (data.generated_at || "n/a") + " (Live)";

          const topicsContainer = document.getElementById("obs-topics-container");
          if (topicsContainer && data.topics && Array.isArray(data.topics) && data.topics.length > 0) {
            topicsContainer.textContent = "";
            data.topics.forEach(t => {
              const topicDiv = document.createElement("div");
              topicDiv.className = "topic";
              const h3 = document.createElement("h3");
              h3.textContent = t.title || "Untitled";
              topicDiv.appendChild(h3);
              if (t.summary) {
                const p = document.createElement("p");
                p.textContent = t.summary;
                topicDiv.appendChild(p);
              }
              const pSources = document.createElement("p");
              pSources.innerHTML = "<strong>Sources:</strong> " + (t.sources ? t.sources.length : 0);
              topicDiv.appendChild(pSources);
              topicsContainer.appendChild(topicDiv);
            });
          }

          statusEl.textContent = "✓ Live data loaded";
          statusEl.style.color = "var(--ok)";
          if (isDebug) preEl.textContent = JSON.stringify(data, null, 2);
        } catch (e) {
          statusEl.textContent = "✗ Runtime fetch failed: " + String(e);
          statusEl.style.color = "var(--fail)";
          if (isDebug) console.error("Observatory Runtime Fetch Error:", e);
        }
      })();
    </script>


    <% if (data) { %>
    
    <!-- Source Metadata -->
    <div class="section">
      <div class="meta">
        <div class="meta-item">
          <strong>Generated</strong>
          <span id="obs-generated-at"><%= data.generated_at || "n/a" %></span>
        </div>
        <div class="meta-item">
          <strong>Source</strong>
          <span id="obs-source-desc">
            <% if (typeof data.source === 'string') { %>
              <%= data.source %>
            <% } else if (data.source && typeof data.source === 'object') { %>
              <%= data.source.source_type %>: <%= data.source.ref %>
            <% } else { %>
              n/a
            <% } %>
          </span>
        </div>
        <div class="meta-item">
          <strong>Observatory ID</strong>
          <span><%= data.observatory_id || "n/a" %></span>
        </div>
        <div class="meta-item">
          <strong>Data Source</strong>
          <% if (locals.view_meta && locals.view_meta.source_kind === 'artifact') { %>
            <span>Artefakt</span>
          <% } else if (locals.view_meta && locals.view_meta.source_kind === 'fixture') { %>
            <span style="color: var(--warn);">Fixture (Fallback)</span>
          <% } else { %>
            <span>unknown</span>
          <% } %>
        </div>
      </div>
    </div>

    <% if (locals.view_meta && locals.view_meta.source_kind === 'fixture') { %>
      <div class="warning-box">
        <strong>⚠️ Fallback Mode:</strong> Live data not available; showing fixture data.
      </div>
    <% } %>

    <!-- Heimgeist Self-State -->
    <% if (locals.selfState && locals.selfState.current) { %>
    <div class="section">
      <div class="section-title">Heimgeist Self-State</div>
      <div class="meta">
        <div class="meta-item">
          <strong>Source</strong>
          <% if (locals.view_meta && locals.view_meta.self_state_source_kind === 'artifact') { %>
            <span>Artefakt</span>
          <% } else { %>
            <span>Fixture</span>
          <% } %>
        </div>
        <div class="meta-item">
          <strong>Autonomy Level</strong>
          <span><%= locals.selfState.current.autonomy_level %></span>
        </div>
        <% if (locals.selfState.schema) { %>
          <div class="meta-item">
            <strong>Schema</strong>
            <span><%= locals.selfState.schema %></span>
          </div>
        <% } %>
      </div>

      <% if (locals.view_meta && locals.view_meta.self_state_schema_valid === false) { %>
        <div class="warning-box" style="margin-top: 12px;">
          <strong>⚠️ Schema Mismatch:</strong> Artifact does not match heimgeist.self_state.bundle.v1.
        </div>
      <% } %>

      <!-- Metrics Grid -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; margin-top: 16px;">
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.5em; font-weight: 700; color: var(--accent);"><%= (locals.selfState.current.confidence * 100).toFixed(0) %>%</div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Confidence</div>
        </div>
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.5em; font-weight: 700; color: var(--warn);"><%= (locals.selfState.current.fatigue * 100).toFixed(0) %>%</div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Fatigue</div>
        </div>
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.5em; font-weight: 700; color: var(--fail);"><%= (locals.selfState.current.risk_tension * 100).toFixed(0) %>%</div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Risk Tension</div>
        </div>
      </div>

      <!-- Basis Signals -->
      <% if (locals.selfState.current.basis_signals && locals.selfState.current.basis_signals.length > 0) { %>
        <div style="margin-top: 16px;">
          <strong style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">Basis Signals</strong>
          <ul style="margin-top: 8px; color: var(--text-secondary); font-size: 0.85em; list-style: none; padding-left: 0;">
            <% locals.selfState.current.basis_signals.forEach(function(signal) { %>
              <li style="padding-left: 20px; position: relative; margin-bottom: 4px;">
                <span style="position: absolute; left: 0; color: var(--text-muted);">▪</span>
                <%= signal %>
              </li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <!-- History -->
      <% if (locals.selfState.history && locals.selfState.history.length > 0) { %>
        <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-glass);">
          <strong style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">History (Last 7 Snapshots)</strong>
          <table style="width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 0.8em;">
            <thead>
              <tr style="border-bottom: 1px solid var(--border-glass);">
                <th style="padding: 8px; text-align: left; color: var(--text-muted);">Time</th>
                <th style="padding: 8px; text-align: left; color: var(--text-muted);">Autonomy</th>
                <th style="padding: 8px; text-align: center; color: var(--text-muted);">Conf.</th>
                <th style="padding: 8px; text-align: center; color: var(--text-muted);">Fatigue</th>
                <th style="padding: 8px; text-align: center; color: var(--text-muted);">Risk</th>
              </tr>
            </thead>
            <tbody>
              <% locals.selfState.history.slice(0, 7).forEach(function(snap) { %>
                <tr style="border-bottom: 1px solid var(--border-glass); color: var(--text-secondary);">
                  <td style="padding: 8px;"><%= snap.timestamp %></td>
                  <td style="padding: 8px;"><%= snap.state.autonomy_level %></td>
                  <td style="padding: 8px; text-align: center;"><%= (snap.state.confidence * 100).toFixed(0) %>%</td>
                  <td style="padding: 8px; text-align: center;"><%= (snap.state.fatigue * 100).toFixed(0) %>%</td>
                  <td style="padding: 8px; text-align: center;"><%= (snap.state.risk_tension * 100).toFixed(0) %>%</td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
    <% } %>

    <!-- Plexer Delivery Status -->
    <% if (locals.plexerDelivery && locals.plexerDelivery.counts) { %>
    <div class="section">
      <div class="section-title">Plexer Delivery Status</div>
      <%
        const pCounts = locals.plexerDelivery.counts;
        const pending = pCounts.pending || 0;
        const failed = pCounts.failed || 0;
        let pStatus = 'OK';
        let pColor = '--ok';
        if (failed > 0) { pStatus = 'FAIL'; pColor = '--fail'; }
        else if (pending > 10) { pStatus = 'BUSY'; pColor = '--warn'; }
      %>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <div>
          <strong style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">Status</strong>
          <div style="margin-top: 4px; font-weight: 600; color: var(<%= pColor %>);"><%= pStatus %></div>
        </div>
        <% if (locals.plexerDelivery.last_retry_at) { %>
          <div style="text-align: right; color: var(--text-secondary); font-size: 0.85em;">
            <div style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">Last Retry</div>
            <div style="margin-top: 4px;"><%= locals.plexerDelivery.last_retry_at %></div>
          </div>
        <% } %>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 12px;">
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.5em; font-weight: 700; color: var(--accent);"><%= pending %></div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Pending</div>
        </div>
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.5em; font-weight: 700; color: <%= failed > 0 ? 'var(--fail)' : 'var(--ok)' %>;"><%= failed %></div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Failed</div>
        </div>
      </div>
      <% if (locals.plexerDelivery.last_error) { %>
        <div class="warning-box" style="margin-top: 12px;">
          <strong>Last Error:</strong> <%= locals.plexerDelivery.last_error %>
        </div>
      <% } %>
    </div>
    <% } %>

    <!-- System Integrity -->
    <% if (locals.integritySummaries && locals.integritySummaries.length > 0) { %>
    <div class="section">
      <div class="section-title">System Integrity</div>
      <%
        const reposMap = new Map();
        if (locals.fleetMetrics && locals.fleetMetrics.repos) {
          locals.fleetMetrics.repos.forEach(r => {
            const name = typeof r === 'string' ? r : (r.name || 'unknown');
            reposMap.set(name, { name, status: 'MISSING', isMissing: true });
          });
        }
        locals.integritySummaries.forEach(s => {
          if (s.repo) reposMap.set(s.repo, { ...s, isMissing: false });
        });
        const repoList = Array.from(reposMap.values()).sort((a, b) => 
          (a.name || 'unknown').localeCompare(b.name || 'unknown')
        );

        let statusRank = 0;
        let aggGap = 0, aggClaims = 0, aggArtifacts = 0;
        repoList.forEach(s => {
          aggGap += (s.counts?.loop_gaps || 0);
          aggClaims += (s.counts?.claims || 0);
          aggArtifacts += (s.counts?.artifacts || 0);
          const st = (s.status || 'OK').toUpperCase();
          if (s.isMissing) statusRank = Math.max(statusRank, 4);
          else if (st === 'FAIL' || st === 'GAP') statusRank = Math.max(statusRank, 4);
          else if (st === 'WARN') statusRank = Math.max(statusRank, 2);
          else if (st === 'UNCLEAR') statusRank = Math.max(statusRank, 1);
        });

        let aggStatus = 'OK', aggColor = '--ok';
        if (statusRank >= 4) { aggStatus = 'FAIL'; aggColor = '--fail'; }
        else if (statusRank >= 2) { aggStatus = 'WARN'; aggColor = '--warn'; }
        else if (statusRank >= 1) { aggStatus = 'UNCLEAR'; aggColor = '--unknown'; }
      %>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <div>
          <strong style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">Status</strong>
          <div style="margin-top: 4px; font-weight: 600; color: var(<%= aggColor %>);"><%= aggStatus %></div>
        </div>
      </div>
      <table style="width: 100%; border-collapse: collapse; font-size: 0.8em;">
        <thead>
          <tr style="border-bottom: 1px solid var(--border-glass);">
            <th style="padding: 8px; text-align: left; color: var(--text-muted);">Repo</th>
            <th style="padding: 8px; text-align: left; color: var(--text-muted);">Status</th>
            <th style="padding: 8px; text-align: left; color: var(--text-muted);">Counts</th>
            <th style="padding: 8px; text-align: left; color: var(--text-muted);">Generated</th>
          </tr>
        </thead>
        <tbody>
          <% repoList.forEach(function(s) { %>
            <%
              const status = (s.status || 'UNCLEAR').toUpperCase();
              let statusColor = '--unknown';
              if (s.isMissing) statusColor = '--unknown';
              else if (status === 'OK') statusColor = '--ok';
              else if (status === 'WARN') statusColor = '--warn';
              else if (status === 'FAIL' || status === 'GAP') statusColor = '--fail';
            %>
            <tr style="border-bottom: 1px solid var(--border-glass); color: var(--text-secondary);">
              <td style="padding: 8px; font-weight: 600;"><%= s.name || 'unknown' %></td>
              <td style="padding: 8px; color: var(<%= statusColor %>);"><%= s.isMissing ? 'MISSING' : status %></td>
              <td style="padding: 8px; font-size: 0.75em;">
                <% if (s.counts && typeof s.counts === 'object') { %>
                  <% Object.keys(s.counts).slice(0, 3).forEach((k, i, arr) => { %>
                    <%= k %>: <strong><%= s.counts[k] %></strong><%= i < arr.length - 1 ? ' | ' : '' %>
                  <% }); %>
                <% } else { %>
                  —
                <% } %>
              </td>
              <td style="padding: 8px; font-size: 0.75em;"><%= s.generated_at || '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 12px; margin-top: 16px;">
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.2em; font-weight: 700; color: var(--accent);"><%= aggClaims %></div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Total Claims</div>
        </div>
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.2em; font-weight: 700; color: var(--accent);"><%= aggArtifacts %></div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Total Artifacts</div>
        </div>
        <div style="background: var(--bg-glass); border: 1px solid var(--border-glass); padding: 12px; border-radius: 8px; text-align: center;">
          <div style="font-size: 1.2em; font-weight: 700; color: var(--fail);"><%= aggGap %></div>
          <div style="color: var(--text-muted); font-size: 0.75em; margin-top: 4px;">Total Gaps</div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Published Knowledge -->
    <% if (locals.insightsDaily) { %>
    <div class="section">
      <div class="section-title">Verdichtete Erkenntnis (Published Daily)</div>
      <div class="meta">
        <div class="meta-item">
          <strong>Date</strong>
          <span><%= locals.insightsDaily.ts || 'n/a' %></span>
        </div>
        <% if (locals.insightsDaily.source) { %>
          <div class="meta-item">
            <strong>Source</strong>
            <span><%= locals.insightsDaily.source %></span>
          </div>
        <% } %>
        <% if (locals.insightsDaily.metadata && locals.insightsDaily.metadata.generated_at) { %>
          <div class="meta-item">
            <strong>Generated</strong>
            <span><%= locals.insightsDaily.metadata.generated_at %></span>
          </div>
        <% } %>
      </div>

      <% if (locals.insightsDaily.topics && locals.insightsDaily.topics.length > 0) { %>
        <div style="margin-top: 16px;">
          <strong style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">Topics (Weighted)</strong>
          <ul style="margin-top: 8px; color: var(--text-secondary); font-size: 0.85em; list-style: none; padding-left: 0;">
            <% locals.insightsDaily.topics.forEach(function(t) { %>
              <li style="padding-left: 20px; position: relative; margin-bottom: 4px;">
                <span style="position: absolute; left: 0; color: var(--text-muted);">▪</span>
                <%= t[0] %> <span style="color: var(--text-muted);">(<%= t[1] %>)</span>
              </li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <% if (locals.insightsDaily.questions && locals.insightsDaily.questions.length > 0) { %>
        <div style="margin-top: 16px;">
          <strong style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">Open Questions</strong>
          <ul style="margin-top: 8px; color: var(--text-secondary); font-size: 0.85em; list-style: none; padding-left: 0;">
            <% locals.insightsDaily.questions.forEach(function(q) { %>
              <li style="padding-left: 20px; position: relative; margin-bottom: 4px;">
                <span style="position: absolute; left: 0; color: var(--text-muted);">▪</span>
                <%= q %>
              </li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <% if (locals.insightsDaily.deltas && locals.insightsDaily.deltas.length > 0) { %>
        <div style="margin-top: 16px;">
          <strong style="color: var(--text-muted); font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.05em;">Deltas (Changes)</strong>
          <ul style="margin-top: 8px; color: var(--text-secondary); font-size: 0.85em; list-style: none; padding-left: 0;">
            <% locals.insightsDaily.deltas.forEach(function(d) { %>
              <li style="padding-left: 20px; position: relative; margin-bottom: 4px;">
                <span style="position: absolute; left: 0; color: var(--text-muted);">▪</span>
                <%= d %>
              </li>
            <% }); %>
          </ul>
        </div>
      <% } %>
    </div>
    <% } %>


    <!-- Raw Knowledge Section -->
    <% if (data.insights && data.insights.length > 0) { %>
    <div class="section">
      <div class="section-title">Insights / Conflicts</div>
      <% data.insights.forEach(function(insight) { %>
        <% if (insight.type === 'insight.negation') { %>
          <div class="insight-card negation">
            <h4>Conflict Detected</h4>
            <div class="insight-meta">ID: <%= insight.id %></div>
            <div class="verdict">Verdict: <%= insight.verdict %></div>
            <% if (insight.relation) { %>
              <div class="relation">
                <span class="relation-item">Thesis: <%= insight.relation.thesis %></span>
                <span class="relation-item">Antithesis: <%= insight.relation.antithesis %></span>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="insight-card">
            <h4><%= insight.type || 'Generic Insight' %></h4>
            <div class="insight-meta">ID: <%= insight.id %></div>
          </div>
        <% } %>
      <% }); %>
    </div>
    <% } %>

    <!-- Topics Section -->
    <div class="section">
      <div class="section-title">Topics</div>
      <div id="obs-topics-container">
        <% if (data.topics && data.topics.length > 0) { %>
          <% data.topics.forEach(function(topic) { %>
            <div class="topic">
              <h3><%= topic.title %></h3>
              <% if (topic.summary) { %>
                <p><%= topic.summary %></p>
              <% } %>
              <p><strong>Sources:</strong> <%= topic.sources ? topic.sources.length : 0 %></p>
            </div>
          <% }); %>
        <% } else { %>
          <p style="color: var(--text-secondary);">No topics available.</p>
        <% } %>
      </div>
    </div>

    <% } else { %>
    <!-- EMPTY STATE -->
    <div class="empty-state">
      <h3>Keine Observatorium-Daten verfügbar</h3>
      <p style="color: var(--text-secondary); margin: 12px 0;">
        <% if (locals.view_meta && locals.view_meta.is_strict) { %>
          Strict Mode ist aktiviert und erforderliche Artefakte fehlen.
        <% } else { %>
          Keine Daten vorhanden.
        <% } %>
      </p>
      <% if (locals.view_meta && locals.view_meta.missing_reason) { %>
        <p style="margin: 12px 0; font-family: ui-monospace; font-size: 0.8em; color: var(--text-muted);">
          <strong>Grund:</strong> <%= locals.view_meta.missing_reason %>
        </p>
      <% } %>
    </div>
    <% } %>

  </main>
</body>
</html>
